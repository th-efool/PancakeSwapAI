{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "agents/**/*.ts",
    "core/**/*.ts",
    "strategies/**/*.ts",
    "types/**/*.ts",
    "index.ts",
    "config.ts"
  ],
  "exclude": ["node_modules", "dashboard", "pancakeswap-ai"]
}
