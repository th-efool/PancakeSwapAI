{
  "name": "eval-suite-swap-planner",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "evals/suites/swap-planner",
  "tags": ["type:eval-suite"],
  "targets": {
    "eval": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx promptfoo eval --config evals/suites/swap-planner/promptfoo.yaml --no-cache",
        "cwd": "{workspaceRoot}"
      },
      "inputs": [
        "{projectRoot}/**/*.md",
        "{projectRoot}/**/*.yaml",
        "{workspaceRoot}/packages/plugins/pancakeswap-driver/skills/swap-planner/SKILL.md"
      ],
      "cache": true
    }
  }
}
