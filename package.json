{
  "name": "pancakeswap-ai-bot",
  "version": "1.0.0",
  "description": "AI-powered PancakeSwap trading bot (DRY_RUN MVP)",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "start:backend": "node dist/index.js",
    "dev:frontend": "npm --prefix dashboard run dev",
    "dev": "concurrently \"npm run start:backend\" \"npm run dev:frontend\"",
    "dev:full": "npm run build && npm run dev"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
